---
import type { MarkdownHeading } from "astro";
import "../styles/prose.css";
import ArticleToc from "../components/ArticleToc.astro";
import BaseLayout from "./BaseLayout.astro";
import Giscus from "../components/Giscus.astro";
import MermaidRuntime from "../components/MermaidRuntime.astro";
import ScrollJumps from "../components/ScrollJumps.astro";

interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  tags?: string[];
  category?: string;
  series?: string;
  seriesItems?: { slug: string; title: string; order?: number; pubDate?: Date }[];
  currentSlug?: string;
  prevInSeries?: { slug: string; title: string; order?: number };
  nextInSeries?: { slug: string; title: string; order?: number };
  showComments?: boolean;
  headings?: MarkdownHeading[];
  /** `true` 左侧目录；`inline` 文首目录；`false` 关闭 */
  toc?: boolean | "inline";
}

const {
  title,
  description,
  pubDate,
  tags = [],
  category = "未分类",
  series,
  seriesItems = [],
  currentSlug,
  prevInSeries,
  nextInSeries,
  showComments = true,
  headings = [],
  toc = true
} = Astro.props;

// MDX 正文里允许使用 h1 作为“一级标题”（如 `# 1 xxx`）。
// 目录只收集正文 headings（Astro 的 headings 会包含 slug 的标题），并限制到 h1–h5。
const tocHeadings = headings.filter((h) => h.depth >= 1 && h.depth <= 5 && h.slug);
const tocOn = toc !== false;
const showSidebarToc = tocOn && toc !== "inline" && tocHeadings.length > 0;
const showInlineToc = tocOn && toc === "inline" && tocHeadings.length > 0;
---

<BaseLayout title={title} description={description}>
  <article class="card article">
    <header class="article-header">
      <p class="article-meta muted">{pubDate?.toLocaleDateString("zh-CN")} · {category}</p>
      <h1 class="article-title">{title}</h1>
      {!!description && <p class="article-desc muted">{description}</p>}
      <div class="tag-list">
        {tags.map((tag) => <a class="tag" href={`/tags/${tag}`}>#{tag}</a>)}
      </div>
      {
        series && (
          <p class="series muted">
            所属专题：<a href={`/series/${encodeURIComponent(series)}`}>{series}</a>
          </p>
        )
      }
    </header>
    <div class:list={["article-body", { "article-body--with-toc": showSidebarToc }]}>
      {showSidebarToc && <ArticleToc headings={tocHeadings} variant="sidebar" />}
      <div class="article-main">
        {showInlineToc && <ArticleToc headings={tocHeadings} variant="inline" />}
        <div class="content prose">
          <slot />
        </div>
      </div>
    </div>
  </article>
  {
    series && seriesItems.length > 0 && (
      <>
        <aside class="card series-nav">
          <h3>本专题文章</h3>
          <ol>
            {seriesItems.map((item) => (
              <li>
                <a class={item.slug === currentSlug ? "active" : ""} href={`/posts/${item.slug}`}>
                  {item.order ? `第 ${item.order} 篇 · ` : ""}
                  {item.title}
                </a>
              </li>
            ))}
          </ol>
        </aside>
        {(prevInSeries || nextInSeries) && (
          <nav class="card series-pager" aria-label="专题上下篇导航">
            {prevInSeries ? (
              <a class="pager-link" href={`/posts/${prevInSeries.slug}`}>
                <span class="muted">上一篇</span>
                <strong>{prevInSeries.title}</strong>
              </a>
            ) : (
              <span />
            )}
            {nextInSeries ? (
              <a class="pager-link align-right" href={`/posts/${nextInSeries.slug}`}>
                <span class="muted">下一篇</span>
                <strong>{nextInSeries.title}</strong>
              </a>
            ) : (
              <span />
            )}
          </nav>
        )}
      </>
    )
  }
  {showComments && <Giscus />}
  <MermaidRuntime />
  <ScrollJumps />
</BaseLayout>

<style>
  .article {
    padding: 1.5rem 1.45rem 1.6rem;
    border-radius: var(--radius-lg);
  }
  .article-header {
    margin-bottom: 0.25rem;
    padding-bottom: 0.15rem;
  }
  .article-meta {
    font-size: 0.88rem;
    letter-spacing: 0.02em;
    margin: 0 0 0.6rem;
  }
  .article-title {
    margin: 0 0 0.65rem;
    font-size: clamp(1.55rem, 4vw, 2.05rem);
    font-weight: 700;
    letter-spacing: -0.035em;
    line-height: 1.25;
    color: var(--text);
  }
  .article-desc {
    margin: 0 0 1rem;
    font-size: 1.02rem;
    line-height: 1.65;
    max-width: 52ch;
  }
  .tag-list {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .article-body {
    margin-top: 1.35rem;
    padding-top: 1.45rem;
    position: relative;
    display: grid;
    gap: 1.25rem;
    align-items: start;
  }

  .article-body--with-toc {
    grid-template-columns: minmax(0, 1fr);
  }

  @media (min-width: 1080px) {
    .article-body--with-toc {
      grid-template-columns: minmax(11rem, 13.5rem) minmax(0, 1fr);
      gap: 1.75rem;
    }
  }

  .article-main {
    min-width: 0;
  }

  .content {
    position: relative;
  }
  .article-body::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: min(100%, 42rem);
    height: 1px;
    background: linear-gradient(90deg, var(--line-strong), transparent);
    border-radius: 1px;
  }
  .series {
    margin-top: 0.8rem;
  }
  .series-nav {
    margin-top: 1rem;
    padding: 1.1rem 1.15rem;
    border-radius: var(--radius);
  }
  .series-nav h3 {
    margin-top: 0;
  }
  .series-nav ol {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.4rem;
  }
  .series-nav a {
    color: var(--text-soft);
  }
  .series-nav a.active {
    color: var(--text);
    font-weight: 600;
  }
  .series-pager {
    margin-top: 1rem;
    padding: 0.9rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.8rem;
  }
  .pager-link {
    display: grid;
    gap: 0.3rem;
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 0.7rem;
  }
  .align-right {
    text-align: right;
  }
  @media (max-width: 720px) {
    .series-pager {
      grid-template-columns: 1fr;
    }
    .align-right {
      text-align: left;
    }
  }
</style>
