---
import BaseLayout from "./BaseLayout.astro";
import Giscus from "../components/Giscus.astro";

interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  tags?: string[];
  category?: string;
  showComments?: boolean;
}

const {
  title,
  description,
  pubDate,
  tags = [],
  category = "未分类",
  showComments = true
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="card article">
    <header>
      <p class="muted">{pubDate?.toLocaleDateString("zh-CN")} · {category}</p>
      <h1>{title}</h1>
      {!!description && <p class="muted">{description}</p>}
      <div class="tag-list">
        {tags.map((tag) => <a class="tag" href={`/tags/${tag}`}>#{tag}</a>)}
      </div>
    </header>
    <div class="content">
      <slot />
    </div>
  </article>
  {showComments && <Giscus />}
</BaseLayout>

<style>
  .article {
    padding: 1.2rem;
  }
  .tag-list {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .content {
    margin-top: 1rem;
    line-height: 1.8;
  }
  h1 {
    margin: 0.25rem 0 0.75rem;
  }
</style>
