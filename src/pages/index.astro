---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("posts"))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const projects = (await getCollection("projects"))
  .filter((item) => !item.data.draft)
  .slice(0, 4);

const totalPosts = (await getCollection("posts")).filter((item) => !item.data.draft).length;
const totalProjects = (await getCollection("projects")).filter((item) => !item.data.draft).length;
---

<BaseLayout title="zhang-llmlab | 首页" description="个人网站、文章与作品集">
  <section class="hero card">
    <div class="hero-grid">
      <div>
        <p class="kicker">PORTFOLIO · NOTES</p>
        <h1>用工程化方式记录思考，展示作品。</h1>
        <p class="muted">
          这里是 zhang-llmlab 的个人网站。包含技术笔记、项目复盘、以及可持续维护的作品集页面。
        </p>
        <div class="cta">
          <a class="btn" href="/projects">查看作品集</a>
          <a class="btn ghost" href="/posts">阅读文章</a>
        </div>
      </div>
      <div class="stats">
        <div class="stat card"><strong>{totalPosts}</strong><span class="muted">文章</span></div>
        <div class="stat card"><strong>{totalProjects}</strong><span class="muted">项目</span></div>
        <div class="stat card"><strong>100%</strong><span class="muted">静态部署</span></div>
      </div>
    </div>
  </section>

  <section class="block">
    <div class="head">
      <h2>最新文章</h2>
      <a href="/posts" class="muted">查看全部</a>
    </div>
    <div class="grid">
      {posts.map((post) => (
        <a class="card item" href={`/posts/${post.slug}`}>
          <h3>{post.data.title}</h3>
          <p class="muted">{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="block">
    <div class="head">
      <h2>精选项目</h2>
      <a href="/projects" class="muted">查看全部</a>
    </div>
    <div class="grid">
      {projects.map((project) => (
        <a class="card item" href={`/projects/${project.slug}`}>
          <h3>{project.data.title}</h3>
          <p class="muted">{project.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 2rem;
    margin-bottom: 1rem;
    position: relative;
    overflow: hidden;
  }
  .hero::after {
    content: "";
    position: absolute;
    width: 420px;
    height: 420px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(124, 92, 255, 0.28) 0%, transparent 70%);
    right: -120px;
    top: -120px;
    pointer-events: none;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 1rem;
    align-items: end;
  }
  .kicker {
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    margin-bottom: 0.5rem;
    color: var(--brand-2);
  }
  .block {
    margin-top: 1.4rem;
  }
  .head {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 0.8rem;
  }
  .cta {
    display: flex;
    gap: 0.7rem;
    margin-top: 1rem;
  }
  .btn {
    border-radius: 999px;
    padding: 0.6rem 0.9rem;
    background: linear-gradient(120deg, var(--brand), var(--brand-2));
    color: #fff;
    font-size: 0.92rem;
  }
  .btn.ghost {
    background: transparent;
    border: 1px solid var(--line);
    color: var(--text-soft);
  }
  .stats {
    display: grid;
    gap: 0.6rem;
  }
  .stat {
    padding: 0.8rem 0.9rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .stat strong {
    font-size: 1.4rem;
  }
  .item {
    padding: 1rem;
  }
  @media (max-width: 820px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
