---
import fs from "node:fs";
import path from "node:path";
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import HomeHero from "../components/HomeHero.astro";
import Sidebar from "../components/Sidebar.astro";
import { HOME_HERO } from "../site.config";
import { getSidebarData } from "../lib/sidebar-data";

const imageDir = path.join(process.cwd(), "public", "images", "main_page_images");
const imageExt = new Set([".jpg", ".jpeg", ".png", ".webp", ".gif", ".avif"]);

let slideUrls: string[] = [];
try {
  slideUrls = fs
    .readdirSync(imageDir)
    .filter((name) => imageExt.has(path.extname(name).toLowerCase()))
    .sort((a, b) => a.localeCompare(b, undefined, { numeric: true, sensitivity: "base" }))
    .map((name) => `/images/main_page_images/${encodeURIComponent(name)}`);
} catch {
  slideUrls = [];
}

const posts = (await getCollection("posts"))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const projects = (await getCollection("projects"))
  .filter((item) => !item.data.draft)
  .slice(0, 4);

const totalPosts = (await getCollection("posts")).filter((item) => !item.data.draft).length;
const totalProjects = (await getCollection("projects")).filter((item) => !item.data.draft).length;

const heroSlogans = [...HOME_HERO.slogans];

const sidebarData = await getSidebarData();
---

<BaseLayout title="zhang-llmlab | 首页" description="个人网站、文章与作品集" fullWidth>
  <Nav variant="overlay" currentPath={Astro.url.pathname} />
  <HomeHero
    slides={slideUrls}
    title={HOME_HERO.title}
    slogans={heroSlogans}
    carouselIntervalMs={HOME_HERO.carouselIntervalMs}
    fadeMs={HOME_HERO.fadeMs}
  />

  <main id="home-main" class="home-main">
    <div class="container home-inner layout-with-sidebar">
      <div class="layout-main">
      <section class="stats-strip card" aria-label="站点概览">
        <div class="stat-cell">
          <strong>{totalPosts}</strong><span class="muted">文章</span>
        </div>
        <div class="stat-cell">
          <strong>{totalProjects}</strong><span class="muted">项目</span>
        </div>
      </section>

      <section class="block">
        <div class="section-head">
          <h2>最新文章</h2>
          <a href="/posts">查看全部</a>
        </div>
        <div class="grid">
          {posts.map((post) => (
            <a class="card item" href={`/posts/${post.slug}`}>
              <span class="item-meta">{post.data.pubDate.toLocaleDateString("zh-CN")}</span>
              <h3>{post.data.title}</h3>
              <p class="muted">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="block">
        <div class="section-head">
          <h2>精选项目</h2>
          <a href="/projects">查看全部</a>
        </div>
        <div class="grid">
          {projects.map((project) => (
            <a class="card item" href={`/projects/${project.slug}`}>
              <h3>{project.data.title}</h3>
              <p class="muted">{project.data.description}</p>
            </a>
          ))}
        </div>
      </section>
      </div>
      <Sidebar series={sidebarData.series} keywords={sidebarData.keywords} />
    </div>
  </main>
</BaseLayout>

<style>
  .home-main {
    scroll-margin-top: 5.5rem;
    padding-top: 2.5rem;
    padding-bottom: 0.5rem;
  }

  .home-inner {
    padding-top: 0.25rem;
  }

  .stats-strip {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    padding: 1rem 1.15rem;
    margin-bottom: 0.25rem;
    border-radius: var(--radius-lg);
  }

  .stat-cell {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    align-items: flex-start;
    min-width: 0;
  }

  .stat-cell strong {
    font-size: 1.35rem;
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }

  .block {
    margin-top: 1.35rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(248px, 1fr));
    gap: 1rem;
  }

  .item {
    padding: 1.05rem 1.15rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-height: 7.5rem;
  }

  .item-meta {
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .item h3 {
    margin: 0;
    font-size: 1.06rem;
    font-weight: 650;
    letter-spacing: -0.02em;
    line-height: 1.35;
    color: var(--text);
  }

  .item p {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.55;
    flex: 1;
  }

  @media (max-width: 560px) {
    .stats-strip {
      grid-template-columns: 1fr;
    }
  }
</style>
