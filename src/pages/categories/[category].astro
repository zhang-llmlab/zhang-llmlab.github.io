---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("posts")).filter((item) => !item.data.draft);
  const projects = (await getCollection("projects")).filter((item) => !item.data.draft);
  const categories = new Set<string>();

  [...posts, ...projects].forEach((entry) => {
    categories.add(entry.data.category);
  });

  return Array.from(categories).map((category) => ({
    params: { category: encodeURIComponent(category) }
  }));
}

// 分类名里可能含「/」（如 AI/Agent）；必须整段编码，否则会被当成多段路径导致构建失败。
const category = decodeURIComponent(Astro.params.category ?? "");
const posts = (await getCollection("posts")).filter(
  (item) => !item.data.draft && item.data.category === category
);
const projects = (await getCollection("projects")).filter(
  (item) => !item.data.draft && item.data.category === category
);
---

<BaseLayout title={`分类：${category} | zhang-llmlab`}>
  <h1 class="page-title">分类：{category}</h1>
  <section class="block">
    <h2 class="sub">文章</h2>
    <ul class="link-list">
      {posts.map((item) => (
        <li>
          <a class="card row" href={`/posts/${item.slug}`}>
            <span>{item.data.title}</span>
            <span class="muted date">{item.data.pubDate.toLocaleDateString("zh-CN")}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
  <section class="block">
    <h2 class="sub">项目</h2>
    <ul class="link-list">
      {projects.map((item) => (
        <li>
          <a class="card row" href={`/projects/${item.slug}`}>
            <span>{item.data.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .block {
    margin-top: 1.1rem;
  }
  .block:first-of-type {
    margin-top: 0.35rem;
  }
  .sub {
    margin: 0 0 0.65rem;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text-soft);
  }
  .link-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.65rem;
  }
  .link-list li {
    margin: 0;
  }
  .row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1rem;
    border-radius: var(--radius);
    font-weight: 500;
    font-size: 0.95rem;
  }
  .date {
    flex-shrink: 0;
    font-size: 0.85rem;
    font-weight: 400;
    font-variant-numeric: tabular-nums;
  }
</style>
