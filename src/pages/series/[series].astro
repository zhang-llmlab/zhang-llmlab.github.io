---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("posts")).filter((item) => !item.data.draft && item.data.series);
  const names = new Set<string>();
  posts.forEach((post) => names.add(post.data.series as string));
  // params 必须为「未编码」字符串；若在此处 encodeURIComponent，会与页面里 href 的编码叠成双重编码，线上易出现 404。
  return Array.from(names).map((series) => ({
    params: { series }
  }));
}

const seriesName = Astro.params.series ?? "";
const posts = (await getCollection("posts"))
  .filter((item) => !item.data.draft && item.data.series === seriesName)
  .sort((a, b) => {
    const orderA = a.data.seriesOrder ?? Number.MAX_SAFE_INTEGER;
    const orderB = b.data.seriesOrder ?? Number.MAX_SAFE_INTEGER;
    if (orderA !== orderB) return orderA - orderB;
    return a.data.pubDate.valueOf() - b.data.pubDate.valueOf();
  });
---

<BaseLayout title={`专题：${seriesName} | zhang-llmlab`}>
  <h1 class="page-title">专题：{seriesName}</h1>
  <div class="list">
    {posts.map((post) => (
      <a class="card row" href={`/posts/${post.slug}`}>
        <div>
          <h3>{post.data.seriesOrder ? `第 ${post.data.seriesOrder} 篇 · ` : ""}{post.data.title}</h3>
          <p class="muted">{post.data.description}</p>
        </div>
        <span class="muted">{post.data.pubDate.toLocaleDateString("zh-CN")}</span>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .list {
    display: grid;
    gap: 0.85rem;
    margin-top: 0.5rem;
  }
  .row {
    padding: 1.05rem 1.15rem;
    display: flex;
    justify-content: space-between;
    align-items: start;
    gap: 1rem;
    border-radius: var(--radius);
  }
  .row h3 {
    margin: 0 0 0.35rem;
    font-size: 1.02rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .row p {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.55;
  }
  .row > span {
    flex-shrink: 0;
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
  }
</style>
