---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const projects = (await getCollection("projects")).filter((item) => !item.data.draft);
---

<BaseLayout title="作品集 | zhang-llmlab">
  <h1 class="page-title">作品集</h1>
  <div class="grid">
    {projects.map((project) => (
      <a class="card project" href={`/projects/${project.slug}`}>
        <h3>{project.data.title}</h3>
        <p class="muted">{project.data.description}</p>
        <div class="chips">
          {project.data.stack.map((tech) => (
            <span class="tag">{tech}</span>
          ))}
        </div>
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 0.9rem;
  }
  .project {
    padding: 1.1rem 1.15rem;
    border-radius: var(--radius);
  }
  .project h3 {
    margin: 0 0 0.45rem;
    font-size: 1.08rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .project p {
    margin: 0;
    font-size: 0.94rem;
    line-height: 1.55;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.7rem;
  }
</style>
