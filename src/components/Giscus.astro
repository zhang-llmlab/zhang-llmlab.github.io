---
interface Props {
  category?: string;
  categoryId?: string;
}

const { category = "General", categoryId = "" } = Astro.props;
const giscusRepo = import.meta.env.PUBLIC_GISCUS_REPO ?? "";
const giscusRepoId = import.meta.env.PUBLIC_GISCUS_REPO_ID ?? "";
const giscusCategory = import.meta.env.PUBLIC_GISCUS_CATEGORY ?? category;
const giscusCategoryId = import.meta.env.PUBLIC_GISCUS_CATEGORY_ID ?? categoryId;
const isConfigured = !!giscusRepo && !!giscusRepoId && !!giscusCategoryId;
---

<section class="card giscus-wrap">
  <h3>评论</h3>
  {
    isConfigured ? (
      <script
        src="https://giscus.app/client.js"
        data-repo={giscusRepo}
        data-repo-id={giscusRepoId}
        data-category={giscusCategory}
        data-category-id={giscusCategoryId}
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="top"
        data-theme="dark"
        data-lang="zh-CN"
        crossorigin="anonymous"
        async
      ></script>
    ) : (
      <p class="muted">
        评论未启用：请在 `.env` 中设置 `PUBLIC_GISCUS_REPO`、`PUBLIC_GISCUS_REPO_ID`、
        `PUBLIC_GISCUS_CATEGORY_ID` 后刷新页面。
      </p>
    )
  }
</section>

<style>
  .giscus-wrap {
    margin-top: 2rem;
    padding: 1rem;
  }
  h3 {
    margin: 0 0 0.5rem;
  }
  p {
    margin-top: 0;
  }
</style>
