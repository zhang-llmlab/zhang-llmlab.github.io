---
interface Props {
  currentPath?: string;
  /** 首页头图：全宽顶栏，与正文区同宽对齐；滚动逻辑由 HomeHero 脚本控制 */
  variant?: "default" | "overlay";
}

const { currentPath = "/", variant = "default" } = Astro.props;

const links = [
  { href: "/", label: "首页" },
  { href: "/posts", label: "文章" },
  { href: "/series", label: "专题" },
  { href: "/projects", label: "作品集" },
  { href: "/search", label: "搜索" }
];

function linkActive(href: string, path: string) {
  const p = path.replace(/\/$/, "") || "/";
  const h = href.replace(/\/$/, "") || "/";
  if (h === "/") return p === "/";
  return p === h || p.startsWith(`${h}/`);
}
---

<nav
  id={variant === "overlay" ? "site-nav" : undefined}
  class:list={[
    "nav",
    variant === "overlay" ? ["nav--overlay", "nav--overlay--at-hero"] : "card"
  ]}
>
  {
    variant === "overlay" ? (
      <div class="nav-inner">
        <a class="brand" href="/">zhang-llmlab</a>
        <div class="items">
          {links.map((link) => (
            <a
              class:list={["nav-link", { active: linkActive(link.href, currentPath) }]}
              href={link.href}
              aria-current={linkActive(link.href, currentPath) ? "page" : undefined}
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    ) : (
      <>
        <a class="brand" href="/">zhang-llmlab</a>
        <div class="items">
          {links.map((link) => (
            <a
              class:list={["nav-link", { active: linkActive(link.href, currentPath) }]}
              href={link.href}
              aria-current={linkActive(link.href, currentPath) ? "page" : undefined}
            >
              {link.label}
            </a>
          ))}
        </div>
      </>
    )
  }
</nav>

<style>
  .nav {
    position: sticky;
    top: 12px;
    z-index: 20;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.85rem 1.1rem;
    margin-bottom: 1.15rem;
    border-radius: var(--radius-lg);
  }

  .nav--overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    margin: 0;
    border-radius: 0;
    padding: 0.75rem clamp(1rem, 4vw, 1.5rem);
    border-bottom: 1px solid transparent;
    transition:
      transform 0.42s var(--ease-out),
      opacity 0.32s ease,
      visibility 0.32s ease,
      background 0.35s ease,
      border-color 0.3s ease,
      box-shadow 0.35s ease,
      backdrop-filter 0.35s ease;
    transform: translateY(0);
    opacity: 1;
    visibility: visible;
  }

  .nav--overlay .nav-inner {
    max-width: var(--content-max, 1200px);
    margin: 0 auto;
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    /* 右上角固定主题按钮，避免与末项导航重叠 */
    padding-inline-end: max(0rem, 2.85rem);
  }

  /* 头图内：完全透明 */
  .nav--overlay--at-hero {
    background: transparent;
    border-bottom-color: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    box-shadow: none;
  }

  .nav--overlay--at-hero .brand {
    color: #fff;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.35);
  }

  .nav--overlay--at-hero .nav-link {
    color: rgba(255, 255, 255, 0.88);
  }

  .nav--overlay--at-hero .nav-link:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.14);
  }

  .nav--overlay--at-hero .nav-link.active {
    color: #fff;
    background: rgba(255, 255, 255, 0.16);
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.22);
  }

  /* 离开头图后向上滑：半透明顶栏 */
  .nav--overlay--peek {
    background: rgba(14, 15, 20, 0.78);
    border-bottom-color: var(--line);
    backdrop-filter: blur(18px) saturate(1.12);
    -webkit-backdrop-filter: blur(18px) saturate(1.12);
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.22);
  }

  .nav--overlay--peek .brand {
    color: var(--text);
    text-shadow: none;
  }

  .nav--overlay--peek .nav-link {
    color: var(--text-soft);
  }

  .nav--overlay--peek .nav-link:hover {
    color: var(--text);
    background: rgba(201, 169, 98, 0.12);
    box-shadow: 0 0 0 1px rgba(201, 169, 98, 0.22);
  }

  .nav--overlay--peek .nav-link.active {
    color: var(--text);
    background: linear-gradient(135deg, rgba(201, 169, 98, 0.2) 0%, rgba(143, 191, 207, 0.1) 100%);
    box-shadow: 0 0 0 1px rgba(201, 169, 98, 0.3);
  }

  /* 离开头图后向下滑：收起 */
  .nav--overlay--hidden {
    transform: translateY(-110%);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .brand {
    font-weight: 700;
    letter-spacing: -0.02em;
    font-size: 1.05rem;
    color: var(--text);
  }

  .items {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem 0.45rem;
    font-size: 0.9rem;
    font-weight: 500;
    padding-inline-end: 2.75rem;
  }

  .nav--overlay .items {
    padding-inline-end: 0;
  }

  .nav-link {
    color: var(--text-soft);
    padding: 0.42rem 0.85rem;
    border-radius: 999px;
    transition:
      color 0.2s cubic-bezier(0.22, 1, 0.36, 1),
      background 0.2s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.2s ease;
  }

  .nav-link:hover {
    color: var(--text);
    background: rgba(201, 169, 98, 0.11);
    box-shadow: 0 0 0 1px rgba(201, 169, 98, 0.2);
  }

  .nav-link.active {
    color: var(--text);
    background: linear-gradient(135deg, rgba(201, 169, 98, 0.18) 0%, rgba(143, 191, 207, 0.09) 100%);
    box-shadow: 0 0 0 1px rgba(201, 169, 98, 0.26);
  }

  @media (max-width: 560px) {
    .nav {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.65rem;
    }

    .nav--overlay .nav-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .items {
      width: 100%;
      justify-content: flex-start;
    }
  }
</style>
