---
interface Props {
  slides: string[];
  title: string;
  slogans: string[];
  carouselIntervalMs?: number;
  fadeMs?: number;
}

const {
  slides,
  title,
  slogans,
  carouselIntervalMs = 7000,
  fadeMs = 1000
} = Astro.props;

const hasSlides = slides.length > 0;
const slogansJson = JSON.stringify(slogans);
---

<section
  class="hero-full"
  aria-label="站点头图"
  data-slogans={slogansJson}
  data-carousel-interval={String(carouselIntervalMs)}
>
  <div class="hero-slides" style={`--hero-fade: ${fadeMs}ms`}>
    {
      hasSlides ? (
        slides.map((src, i) => (
          <div
            class:list={["hero-slide", { active: i === 0 }]}
            data-hero-slide
            data-slide-index={i}
            style={`background-image: url(${JSON.stringify(src)})`}
          />
        ))
      ) : (
        <div class="hero-slide hero-slide--fallback active" data-hero-slide />
      )
    }
  </div>
  <div class="hero-overlay" aria-hidden="true"></div>
  {
    hasSlides && slides.length > 1 && (
      <div class="hero-dots" role="group" aria-label="头图轮播">
        {slides.map((_, i) => (
          <button
            type="button"
            class:list={["hero-dot", { active: i === 0 }]}
            data-hero-dot={i}
            aria-label={`第 ${i + 1} 张，共 ${slides.length} 张`}
            aria-current={i === 0 ? "true" : undefined}
          />
        ))}
      </div>
    )
  }
  <div class="hero-inner">
    <h1 class="hero-site-title">{title}</h1>
    <p class="hero-slogan" aria-live="polite">
      <span id="home-hero-typed" class="hero-typed"></span>
    </p>
    <div class="hero-cta">
      <a class="hero-btn hero-btn--primary" href="/posts">阅读文章</a>
      <a class="hero-btn hero-btn--ghost" href="/projects">作品集</a>
    </div>
  </div>
  <button type="button" class="scroll-cue" id="home-hero-scroll-cue" aria-label="滚动到正文">
    <span class="scroll-cue-ring" aria-hidden="true"></span>
    <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
      <path d="M6 9l6 6 6-6"></path>
    </svg>
  </button>
</section>

<script>
  import Typed from "typed.js";

  function parseSlogans(root) {
    try {
      const raw = root?.getAttribute("data-slogans");
      if (!raw) return [];
      const parsed = JSON.parse(raw);
      return Array.isArray(parsed) ? parsed.map(String) : [];
    } catch {
      return [];
    }
  }

  function scrollToHomeMain() {
    const target = document.getElementById("home-main");
    if (!target) return;
    const top = target.getBoundingClientRect().top + window.scrollY - 12;
    window.scrollTo({ top: Math.max(0, top), behavior: "smooth" });
  }

  function initScrollCue(signal) {
    document.getElementById("home-hero-scroll-cue")?.addEventListener(
      "click",
      (e) => {
        e.preventDefault();
        scrollToHomeMain();
      },
      { signal }
    );
  }

  function initNavScroll(hero, signal) {
    const nav = document.getElementById("site-nav");
    if (!nav || !hero) return;

    let lastY = window.scrollY;
    let hiddenBelowHero = false;
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    function apply() {
      const y = window.scrollY;
      const rect = hero.getBoundingClientRect();
      const heroBottomDoc = y + rect.bottom;
      const pastHero = y >= heroBottomDoc - 16;

      nav.classList.remove("nav--overlay--at-hero", "nav--overlay--peek", "nav--overlay--hidden");

      if (!pastHero) {
        hiddenBelowHero = false;
        nav.classList.add("nav--overlay--at-hero");
        lastY = y;
        return;
      }

      if (reduceMotion) {
        nav.classList.add("nav--overlay--peek");
        lastY = y;
        return;
      }

      const delta = y - lastY;
      if (delta > 8) hiddenBelowHero = true;
      else if (delta < -8) hiddenBelowHero = false;

      if (hiddenBelowHero) nav.classList.add("nav--overlay--hidden");
      else nav.classList.add("nav--overlay--peek");

      lastY = y;
    }

    apply();
    window.addEventListener("scroll", apply, { passive: true, signal });
    window.addEventListener("resize", apply, { passive: true, signal });
  }

  function initCarousel(intervalMs, signal) {
    const slideEls = [...document.querySelectorAll(".hero-full [data-hero-slide]")];
    const dotEls = [...document.querySelectorAll(".hero-full [data-hero-dot]")];
    if (slideEls.length <= 1) return;

    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let idx = 0;
    let timer = null;

    function syncDots() {
      dotEls.forEach((dot, i) => {
        const on = i === idx;
        dot.classList.toggle("active", on);
        if (on) dot.setAttribute("aria-current", "true");
        else dot.removeAttribute("aria-current");
      });
    }

    function goTo(i) {
      const n = slideEls.length;
      idx = ((i % n) + n) % n;
      slideEls.forEach((el, j) => el.classList.toggle("active", j === idx));
      syncDots();
    }

    function stopAuto() {
      if (timer != null) {
        clearInterval(timer);
        timer = null;
      }
    }

    function startAuto() {
      if (reduce) return;
      stopAuto();
      timer = window.setInterval(() => goTo(idx + 1), intervalMs);
    }

    dotEls.forEach((dot) => {
      dot.addEventListener(
        "click",
        () => {
          const i = Number(dot.getAttribute("data-hero-dot"));
          if (Number.isNaN(i)) return;
          stopAuto();
          goTo(i);
          startAuto();
        },
        { signal }
      );
    });

    signal.addEventListener("abort", () => stopAuto(), { once: true });
    startAuto();
  }

  function destroyHomeTyped() {
    try {
      window.__homeTypedDestroy?.();
    } catch (_) {
      /* ignore */
    }
    window.__homeTypedDestroy = null;
  }

  function initTyped(strings) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const el = document.getElementById("home-hero-typed");
    if (!el || !strings.length) return;

    destroyHomeTyped();

    if (reduce) {
      el.textContent = strings[0] ?? "";
      return;
    }

    try {
      const instance = new Typed(el, {
        strings,
        contentType: "text",
        typeSpeed: 40,
        backSpeed: 26,
        backDelay: 2000,
        startDelay: 600,
        loop: true,
        smartBackspace: true,
        showCursor: true,
        cursorChar: "|"
      });
      window.__homeTypedDestroy = () => instance.destroy();
    } catch (err) {
      console.warn("[HomeHero] Typed.js failed, fallback to static slogan.", err);
      el.textContent = strings[0] ?? "";
    }
  }

  let homeLifecycleAc = null;

  function boot() {
    homeLifecycleAc?.abort();
    homeLifecycleAc = new AbortController();
    const signal = homeLifecycleAc.signal;

    const root = document.querySelector(".hero-full");
    const strings = parseSlogans(root);
    const intervalMs = Math.max(3000, Number(root?.getAttribute("data-carousel-interval")) || 7000);

    initScrollCue(signal);

    if (root) {
      initNavScroll(root, signal);
      initCarousel(intervalMs, signal);
    }

    initTyped(strings);
  }

  document.addEventListener("astro:before-swap", () => {
    homeLifecycleAc?.abort();
    destroyHomeTyped();
  });

  document.addEventListener("astro:page-load", boot);
</script>

<style>
  .hero-full {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-slides {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0;
    transition: opacity var(--hero-fade, 1s) ease-in-out;
    transform: scale(1.02);
    filter: brightness(1.36) contrast(1.03) saturate(1.05);
  }

  .hero-slide.active {
    opacity: 1;
    transform: scale(1);
    transition:
      opacity var(--hero-fade, 1s) ease-in-out,
      transform 10s ease-out;
  }

  .hero-slide--fallback {
    background:
      radial-gradient(ellipse 100% 80% at 50% 18%, rgba(201, 169, 98, 0.18), transparent 55%),
      radial-gradient(ellipse 80% 55% at 85% 55%, rgba(143, 80, 70, 0.2), transparent 50%),
      linear-gradient(165deg, #121318 0%, #0a0b0f 48%, #07080c 100%);
    filter: none;
    opacity: 1;
    transform: none;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(6, 5, 8, 0.16) 0%, rgba(8, 6, 10, 0.3) 45%, rgba(6, 5, 8, 0.46) 100%),
      radial-gradient(ellipse 90% 70% at 50% 100%, rgba(0, 0, 0, 0.28), transparent 65%);
    pointer-events: none;
  }

  .hero-overlay::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(125deg, rgba(255, 248, 235, 0.085) 0%, transparent 42%, transparent 100%);
    mix-blend-mode: soft-light;
    pointer-events: none;
  }

  .hero-dots {
    position: absolute;
    bottom: clamp(5.35rem, 12.5vh, 7.25rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 48;
    display: flex;
    gap: 0.45rem;
    align-items: center;
    padding: 0.4rem 0.65rem;
    border-radius: 999px;
    background: rgba(6, 6, 8, 0.42);
    border: 1px solid rgba(255, 245, 230, 0.12);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.2);
  }

  .hero-dot {
    width: 0.5rem;
    height: 0.5rem;
    padding: 0;
    border: none;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.38);
    cursor: pointer;
    transition:
      width 0.35s var(--ease-out, ease),
      background 0.3s ease,
      box-shadow 0.3s ease,
      transform 0.2s ease;
  }

  .hero-dot:hover {
    background: rgba(255, 255, 255, 0.62);
    transform: scale(1.12);
  }

  .hero-dot:focus-visible {
    outline: 2px solid rgba(232, 210, 160, 0.85);
    outline-offset: 3px;
  }

  .hero-dot.active {
    width: 1.4rem;
    background: rgba(232, 210, 160, 0.95);
    box-shadow: 0 0 14px rgba(201, 169, 98, 0.5);
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: clamp(5.5rem, 12vh, 7rem) clamp(1.25rem, 4vw, 2rem) 4rem;
    max-width: 52rem;
    margin: 0 auto;
  }

  .hero-site-title {
    margin: 0;
    font-family: Inter, "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif;
    font-size: clamp(2.35rem, 7vw, 3.85rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1.12;
    color: #faf8f4;
    text-shadow:
      0 1px 2px rgba(0, 0, 0, 0.45),
      0 8px 48px rgba(0, 0, 0, 0.35),
      0 0 80px rgba(201, 169, 98, 0.12);
    animation: hero-title-in 1.1s var(--ease-out, ease) both;
  }

  @keyframes hero-title-in {
    from {
      opacity: 0;
      transform: translateY(14px);
      filter: blur(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  .hero-slogan {
    margin: 1.15rem 0 0;
    min-height: 2.6em;
    font-family: Inter, "Noto Sans SC", "PingFang SC", "Microsoft YaHei", sans-serif;
    font-size: clamp(1rem, 2.4vw, 1.2rem);
    font-weight: 400;
    line-height: 1.55;
    color: rgba(255, 252, 245, 0.94);
    text-shadow: 0 1px 18px rgba(0, 0, 0, 0.5);
    animation: hero-slogan-in 1.15s var(--ease-out, ease) 0.15s both;
  }

  @keyframes hero-slogan-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-slogan :global(.typed-cursor) {
    color: rgba(232, 210, 160, 0.95);
    font-weight: 300;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
    justify-content: center;
    margin-top: 1.75rem;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.58rem 1.25rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 600;
    font-family: inherit;
    transition:
      transform 0.2s var(--ease-out, ease),
      background 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .hero-btn--primary {
    background: linear-gradient(130deg, #d4b56a 0%, #b8944a 42%, #8f6f3a 100%);
    color: #1a1814;
    border: none;
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.35),
      0 0 0 1px rgba(255, 255, 255, 0.12) inset,
      0 0 40px rgba(201, 169, 98, 0.25);
  }

  .hero-btn--primary:hover {
    transform: translateY(-2px);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(255, 255, 255, 0.18) inset,
      0 0 52px rgba(201, 169, 98, 0.35);
  }

  .hero-btn--ghost {
    background: rgba(255, 255, 255, 0.06);
    color: #faf8f4;
    border: 1px solid rgba(255, 245, 230, 0.42);
    backdrop-filter: blur(10px);
  }

  .hero-btn--ghost:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(232, 210, 160, 0.65);
    transform: translateY(-2px);
  }

  .scroll-cue {
    position: absolute;
    bottom: clamp(1.5rem, 5vh, 2.25rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.35rem;
    height: 3.35rem;
    padding: 0;
    border: none;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    color: rgba(255, 252, 245, 0.95);
    cursor: pointer;
    backdrop-filter: blur(12px);
    box-shadow: 0 0 0 1px rgba(255, 245, 230, 0.2);
    transition:
      background 0.25s ease,
      box-shadow 0.25s ease,
      color 0.25s ease;
    animation: scroll-cue-bounce 2.2s ease-in-out infinite;
  }

  .scroll-cue-ring {
    position: absolute;
    inset: -6px;
    border-radius: inherit;
    border: 1px solid rgba(232, 210, 160, 0.35);
    opacity: 0.85;
    animation: scroll-cue-pulse 2.6s ease-in-out infinite;
    pointer-events: none;
  }

  .scroll-cue:hover {
    background: rgba(255, 255, 255, 0.2);
    box-shadow:
      0 0 0 1px rgba(232, 210, 160, 0.45),
      0 8px 32px rgba(0, 0, 0, 0.25);
    animation-play-state: paused;
  }

  @keyframes scroll-cue-bounce {
    0%,
    100% {
      transform: translateX(-50%) translateY(0);
    }
    50% {
      transform: translateX(-50%) translateY(9px);
    }
  }

  @keyframes scroll-cue-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.55;
    }
    50% {
      transform: scale(1.08);
      opacity: 0.95;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue,
    .scroll-cue-ring {
      animation: none;
    }
    .hero-site-title,
    .hero-slogan {
      animation: none;
    }
    .hero-slide.active {
      transition: opacity var(--hero-fade, 1s) ease-in-out;
    }
  }
</style>
