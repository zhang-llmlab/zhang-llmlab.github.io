---
---

<div class="theme-toggle-floating">
  <button
    type="button"
    class="theme-toggle"
    data-theme-toggle
    aria-label="切换浅色或深色主题"
    title="切换主题（全站生效）"
  >
    <span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="4"></circle>
        <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
      </svg>
    </span>
    <span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
    </span>
  </button>
</div>

<style>
  .theme-toggle-floating {
    position: fixed;
    top: 0.85rem;
    right: 1.1rem;
    z-index: 1200;
    pointer-events: none;
  }

  .theme-toggle-floating .theme-toggle {
    pointer-events: auto;
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.45rem;
    height: 2.45rem;
    padding: 0;
    border: none;
    border-radius: 999px;
    background: var(--theme-fab-bg, rgba(201, 169, 98, 0.18));
    color: var(--theme-fab-fg, var(--text));
    box-shadow: var(--theme-fab-shadow, 0 2px 12px rgba(0, 0, 0, 0.2));
    cursor: pointer;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      transform 0.15s ease,
      box-shadow 0.2s ease;
  }

  .theme-toggle:hover {
    background: var(--theme-fab-bg-hover, rgba(201, 169, 98, 0.28));
    transform: scale(1.04);
  }

  .theme-toggle:active {
    transform: scale(0.97);
  }

  html[data-theme="dark"] .theme-toggle__icon--moon {
    display: none;
  }

  html[data-theme="dark"] .theme-toggle__icon--sun {
    display: flex;
  }

  html[data-theme="light"] .theme-toggle__icon--sun {
    display: none;
  }

  html[data-theme="light"] .theme-toggle__icon--moon {
    display: flex;
  }

  .theme-toggle__icon {
    align-items: center;
    justify-content: center;
  }

  html[data-theme="light"] {
    --theme-fab-bg: rgba(255, 255, 255, 0.92);
    --theme-fab-bg-hover: #ffffff;
    --theme-fab-fg: var(--text-soft);
    --theme-fab-shadow: 0 4px 16px rgba(0, 40, 30, 0.12);
  }

  html[data-theme="dark"] {
    --theme-fab-bg: rgba(30, 32, 40, 0.92);
    --theme-fab-bg-hover: rgba(40, 44, 56, 0.98);
    --theme-fab-fg: rgba(242, 240, 236, 0.9);
    --theme-fab-shadow: 0 4px 20px rgba(0, 0, 0, 0.35);
  }
</style>
