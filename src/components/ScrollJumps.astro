<div class="scroll-jumps" aria-label="页面快捷滚动">
  <button type="button" class="scroll-jumps__btn" data-scroll-jump="top" aria-label="回到顶部" title="回到顶部">
    ↑
  </button>
  <button type="button" class="scroll-jumps__btn" data-scroll-jump="bottom" aria-label="回到底部" title="回到底部">
    ↓
  </button>
</div>

<script is:inline>
  (function () {
    function getDocHeight() {
      var body = document.body;
      var html = document.documentElement;
      return Math.max(
        body ? body.scrollHeight : 0,
        body ? body.offsetHeight : 0,
        html ? html.clientHeight : 0,
        html ? html.scrollHeight : 0,
        html ? html.offsetHeight : 0
      );
    }

    function jumpToTop() {
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    function jumpToBottom() {
      var y = Math.max(0, getDocHeight() - window.innerHeight);
      window.scrollTo({ top: y, behavior: "smooth" });
    }

    function bind() {
      document.querySelectorAll("[data-scroll-jump]").forEach(function (btn) {
        btn.addEventListener("click", function () {
          var dir = btn.getAttribute("data-scroll-jump");
          if (dir === "top") jumpToTop();
          else jumpToBottom();
        });
      });
    }

    bind();
    document.addEventListener("astro:page-load", bind);
  })();
</script>

<style>
  .scroll-jumps {
    position: fixed;
    right: 1.1rem;
    bottom: 1.15rem;
    z-index: 90;
    display: grid;
    gap: 0.5rem;
  }

  .scroll-jumps__btn {
    width: 2.35rem;
    height: 2.35rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--card);
    color: var(--text);
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
    box-shadow: var(--shadow-sm);
    backdrop-filter: blur(8px) saturate(1.05);
    -webkit-backdrop-filter: blur(8px) saturate(1.05);
    transition:
      transform 0.16s ease,
      border-color 0.2s ease,
      background 0.2s ease;
  }

  .scroll-jumps__btn:hover {
    transform: translateY(-1px);
    border-color: var(--line-strong);
    background: var(--card-hover);
  }

  @media (max-width: 960px) {
    .scroll-jumps {
      right: 0.8rem;
      bottom: 0.85rem;
    }
  }
</style>
